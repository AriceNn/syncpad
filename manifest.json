{
  "manifest_version": 3,
  "name": "SyncPad & Clipboard",
  "version": "1.0.0",
  "description": "Securely sync your notepad and clipboard history across devices using end-to-end encryption.",
  "permissions": [
    "storage",
    "alarms",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://onfdobqijhaqzrjwqobw.supabase.co/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SyncPad",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
